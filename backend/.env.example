# AIVENTRA backend environment
APP_NAME=AIVENTRA
ENV=development
DEBUG=True

# Server
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Firebase — required for Auth verification
FIREBASE_PROJECT_ID=trace-8e47e
FIREBASE_SERVICE_ACCOUNT_JSON=

# ─── LLM router ──────────────────────────────────────────────────────
# Get a free Gemini API key (15 RPM, 1500/day) at:
#   https://aistudio.google.com/app/apikey
# Without it, the system falls back to local Ollama (TinyLlama) then to
# templated heuristic output.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Local Ollama fallback — install from https://ollama.com
# then run: ollama pull tinyllama && ollama serve
OLLAMA_MODEL=tinyllama

# ─── AI feature flags ────────────────────────────────────────────────
ENABLE_OCR=True
ENABLE_TRANSFORMERS=False
ENABLE_VECTOR_INDEX=False
