rules_version = '2';

// AIVENTRA Firestore security rules
//
// Threat model: authenticated investigators can only access cases they are
// members of. User profiles are owned by their authenticated user.
// Role-based access via custom claims (role: admin | investigator | viewer).

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // VULN-008 fix: check if user is a member of the case
    function isCaseMember(caseId) {
      return isSignedIn()
             && request.auth.uid in get(/databases/$(database)/documents/cases/$(caseId)).data.members;
    }

    // VULN-009 fix: check if user has admin role
    function isAdmin() {
      return isSignedIn()
             && request.auth.token.role == 'admin';
    }

    // User profiles — only the user themselves can read/write their doc.
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid);
      allow update: if isOwner(uid)
                    && request.resource.data.email == resource.data.email;
      allow delete: if false; // users cannot self-delete via the client
    }

    // Cases — VULN-008 fix: per-case ACL via members array.
    match /cases/{caseId} {
      allow read: if isSignedIn()
                  && request.auth.uid in resource.data.members;
      allow create: if isSignedIn()
                    && request.resource.data.title is string
                    && request.resource.data.title.size() > 0
                    && request.auth.uid in request.resource.data.members;
      allow update: if isCaseMember(caseId);
      allow delete: if isAdmin(); // VULN-009 fix: only admins can delete
    }

    // Evidence records — VULN-008 fix: restricted to case members.
    match /evidence/{evId} {
      allow read: if isSignedIn()
                  && isCaseMember(resource.data.case_id);
      allow create: if isSignedIn()
                    && request.resource.data.case_id is string
                    && isCaseMember(request.resource.data.case_id);
      // Disallow shrinking the chain-of-custody trail.
      allow update: if isCaseMember(resource.data.case_id)
                    && (
                      !('chain_of_custody' in resource.data)
                      || request.resource.data.chain_of_custody.size()
                         >= resource.data.chain_of_custody.size()
                    );
      allow delete: if isAdmin(); // VULN-009 fix: only admins can delete
    }

    // Geo markers — VULN-008 fix: restricted to case members
    match /geo_markers/{id} {
      allow read: if isSignedIn()
                  && isCaseMember(resource.data.case_id);
      allow write: if isSignedIn()
                   && isCaseMember(request.resource.data.case_id);
    }

    // Timeline events — VULN-008 fix: restricted to case members
    match /timeline_events/{id} {
      allow read: if isSignedIn()
                  && isCaseMember(resource.data.case_id);
      allow write: if isSignedIn()
                   && isCaseMember(request.resource.data.case_id);
    }

    // AI analyses (autopsy NLP, TOD, risk, image CV) — append-only history
    match /analyses/{id} {
      allow read: if isSignedIn()
                  && isCaseMember(resource.data.case_id);
      allow create: if isSignedIn()
                    && isCaseMember(request.resource.data.case_id);
      // Updates and deletes intentionally restricted — analyses are immutable
      // audit records. To "revise" an analysis, save a new one.
      allow update: if false;
      allow delete: if false;
    }

    // Chat sessions — VULN-008 fix: restricted to session owner
    match /chat_sessions/{id} {
      allow read: if isSignedIn()
                  && resource.data.user_id == request.auth.uid;
      allow create: if isSignedIn()
                    && request.resource.data.user_id == request.auth.uid;
      allow update: if isSignedIn()
                    && resource.data.user_id == request.auth.uid;
      allow delete: if isAdmin();
    }

    // Fallback — deny anything not explicitly listed
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
