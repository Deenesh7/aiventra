# AIVENTRA frontend environment

# Backend AI service
VITE_API_BASE_URL=http://localhost:8000/api

# Firebase (defaults are wired into the code for the trace-8e47e project,
# override here only if you're using a different Firebase project)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=

# Cloudinary (for evidence file uploads — Firebase Storage requires paid plan)
# Sign up free at https://cloudinary.com (no card required, 25 GB)
# Then create an unsigned upload preset: Settings → Upload → Upload presets
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name-here
VITE_CLOUDINARY_UPLOAD_PRESET=aiventra-unsigned
